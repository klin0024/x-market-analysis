# Playwright / X scraper
X_AUTH_STATE_PATH=auth_state.json
PLAYWRIGHT_HEADLESS=true

# LLM (DeepAgents model string，格式：provider:model-name)
# 即時分析 — 低延遲優先
LLM_FAST_MODEL=google_genai:gemini-3.1-flash-lite
GOOGLE_API_KEY=your_google_api_key_here

# 每日報告 — 品質優先
LLM_SLOW_MODEL=google_genai:gemini-3.1-flash-lite

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_GROUP_IDS={"stock":"C_your_stock_group_id","crypto":"C_your_crypto_group_id"}

# SQLite 資料庫目錄（檔名固定為 xmarket.db）
SQLITE_DIR=data

# Watch list（必須是合法 JSON 陣列，字串用雙引號）
WATCH_ACCOUNTS=["elonmusk","federalreserve"]
WATCH_KEYWORDS=[]
WATCH_HASHTAGS=[]

# Daily report time (UTC HH:MM)
DAILY_REPORT_TIME=10:00

# Alert rules override (optional, leave empty for defaults)
ALERT_RULES_JSON=

# impact_score 過濾開關（true = 達到閾值才推送，false = 所有貼文都推送）
SCORE_FILTER_ENABLED=false

# Fetcher poll 間隔（秒，預設 600）
POLL_INTERVAL_SEC=600
# 首次啟動回溯幾小時的舊文（預設 24）
FETCH_LOOKBACK_HOURS=24

# XPublicScraper 並行爬取數（預設 2）
SCRAPER_MAX_WORKERS=2

# LLM 分析失敗重試次數（預設 2）
LLM_MAX_RETRIES=2

# Flood control（防洪控制）
# FLOOD_CONTROL_ENABLED: 開關（true=啟用，false=關閉）
# FLOOD_MIN_POSTS: 同作者推送 N 筆後才啟動 flood（預設 1）
# FLOOD_COOLDOWN_SEC: 冷卻秒數（預設 1800）
FLOOD_CONTROL_ENABLED=false
FLOOD_MIN_POSTS=3
FLOOD_COOLDOWN_SEC=1800
